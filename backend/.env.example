# PostgreSQL connection string (Supabase, Render, etc.)
# Leave unset for local SQLite fallback (sqlite:///./memory_wall.db)
#
# Supabase tip: use "Session pooler" URI (port 5432), not Transaction pooler (6543).
# If your password contains special characters (@, #, %, etc.), URL-encode them.
DATABASE_URL=postgresql://user:password@host:5432/postgres?sslmode=require
